<!DOCTYPE html>
<html>
<head>
  <title>Admin — Only Bosses</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen p-6 font-mono text-sm">

  <div class="max-w-5xl mx-auto">

    <%# ── Header ──────────────────────────────────────────────────────── %>
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-white">Balance Analysis</h1>
        <p class="text-gray-400 mt-1">
          <%= @run_count %> runs &nbsp;·&nbsp; <%= @snapshot_count %> snapshots
        </p>
      </div>
      <%= link_to "← Home", root_path, class: "text-gray-400 hover:text-white border border-gray-600 rounded px-3 py-1 text-sm" %>
    </div>

    <%# ── Controls ────────────────────────────────────────────────────── %>
    <%= form_with url: admin_path, method: :get, local: true, class: "flex flex-wrap gap-4 items-end mb-8 bg-gray-900 border border-gray-700 rounded-lg p-4" do |f| %>
      <div class="flex flex-col gap-1">
        <%= f.label :depth, "Min depth", class: "text-xs text-gray-400" %>
        <%= f.number_field :depth, value: @min_depth, min: 1, max: 50,
              class: "w-20 bg-gray-800 border border-gray-600 rounded px-2 py-1 text-white text-sm" %>
      </div>
      <div class="flex items-center gap-2 self-end mb-0.5">
        <%= f.check_box :tree, { checked: @use_tree, class: "accent-orange-500" }, "1", "0" %>
        <%= f.label :tree, "Include tree importances", class: "text-xs text-gray-300 cursor-pointer" %>
      </div>
      <%= f.submit "Run Analysis",
            class: "self-end bg-orange-600 hover:bg-orange-500 text-white rounded px-4 py-1 text-sm cursor-pointer" %>
    <% end %>

    <%# ── Error ───────────────────────────────────────────────────────── %>
    <% if @error %>
      <div class="bg-red-950 border border-red-700 rounded-lg p-4 mb-6">
        <p class="text-red-400 font-bold mb-1">Analysis failed</p>
        <pre class="text-red-300 text-xs whitespace-pre-wrap"><%= @error %></pre>
      </div>
    <% end %>

    <%# ── Sections ────────────────────────────────────────────────────── %>
    <% @sections.each do |section| %>
      <div class="mb-6 bg-gray-900 border border-gray-700 rounded-lg overflow-hidden">
        <div class="bg-gray-800 border-b border-gray-700 px-4 py-2">
          <h2 class="text-orange-400 font-bold text-sm uppercase tracking-wide"><%= section[:title] %></h2>
        </div>
        <div class="p-4 overflow-x-auto">
          <pre class="text-gray-200 text-xs leading-5 whitespace-pre"><%= section[:lines].join("\n") %></pre>
        </div>
      </div>
    <% end %>

    <% if @sections.empty? && !@error %>
      <p class="text-gray-500 text-center mt-16">Click "Run Analysis" to generate a report.</p>
    <% end %>

  </div>
</body>
</html>
